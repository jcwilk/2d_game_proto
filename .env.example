# Copy to .env and fill in values as needed (see AGENTS.md).

# Vite: public URL prefix for GitHub Pages project sites (`/<repo>/`). Optional locally; unset = `/` for `npm run dev`. See README and §A.2.1 in .cursor/plans/project-implementation-deep-dive.md
# VITE_BASE=

# wedow/ticket: optional override for the tickets directory (default: ./.tickets)
# TICKETS_DIR=

# Cursor web-research subagent (Perplexity Sonar) — only if you spawn that agent
# PERPLEXITY_API_KEY=

# AI pipeline (see .cursor/plans/project-implementation-deep-dive.md §E.0)
# FAL_KEY=
# OPENAI_API_KEY=
